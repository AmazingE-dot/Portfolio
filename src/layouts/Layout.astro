---
import "../styles/global.css";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Portafolio profesional de ingeniero de sistemas especializado en IA",
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-G-H5DLMN5L51"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-H5DLMN5L51", { debug_mode: true });

      // Esta función envía el evento a Google
      function trackNavigation() {
        const hash = window.location.hash || "#inicio";
        console.log("Enviando evento para:", hash); 
        gtag("event", "page_view", {
          page_title: document.title + " - " + hash,
          page_location: window.location.href,
          page_path: window.location.pathname + hash,
        });
      }

      // 1. Escuchar cuando cambia el hash (clics en el menú)
      window.addEventListener("hashchange", trackNavigation);

      // 2. Escuchar clics directos por si el hashchange falla
      document.addEventListener("click", (event) => {
        const anchor = event.target.closest("a");
        if (anchor && anchor.hash) {
          // Pequeño delay para dejar que la URL cambie antes de disparar
          setTimeout(trackNavigation, 100);
        }
      });
    </script>
    <title>{title}</title>
    <script>
      if (
        localStorage.getItem("theme") === "dark" ||
        (!localStorage.getItem("theme") &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>
  <body>
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
