---
import "../styles/global.css";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Portafolio profesional de ingeniero de sistemas especializado en IA",
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-H5DLMN5L51"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-H5DLMN5L51", { debug_mode: true });

      function trackNavigation() {
        // Un pequeño respiro para que history.pushState termine
        setTimeout(() => {
          const currentHash = window.location.hash || "#inicio";
          console.log("Capturando sección:", currentHash);

          gtag("event", "page_view", {
            page_title: document.title + " - " + currentHash,
            page_location: window.location.href,
            page_path: window.location.pathname + currentHash,
          });
        }, 50);
      }

      // Escuchamos el cambio de hash (ahora forzado por el Navigation.astro)
      window.addEventListener("hashchange", trackNavigation);

      // Captura inicial
      trackNavigation();
    </script>
    <title>{title}</title>
    <script>
      if (
        localStorage.getItem("theme") === "dark" ||
        (!localStorage.getItem("theme") &&
          window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>
  <body>
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
